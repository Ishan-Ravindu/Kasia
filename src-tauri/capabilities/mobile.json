{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "mobile",
  "description": "enables the mobile permissions",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "app-events:default",
    "log:default",
    "clipboard-manager:allow-read-text",
    "biometry:default",
    "barcode-scanner:default",
    "opener:default"
  ],
  "platforms": ["iOS", "android"]
}
